# Copia este archivo a .env y sustituye los valores por los reales.
# Supabase: Dashboard → Project Settings → API (URL + anon public)
# Google: Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
#
# IMPORTANTE: VITE_SUPABASE_URL y VITE_SUPABASE_ANON_KEY deben ser exactamente los mismos
# valores que SUPABASE_URL y SUPABASE_ANON_KEY (o SUPABASE_KEY anon) en backend/.env.
# Si el backend apunta a otro proyecto, get_user(Bearer) fallará y verás 401 en rutas protegidas.

VITE_SUPABASE_URL=https://tu-nuevo-id.supabase.co
VITE_SUPABASE_ANON_KEY=tu-nueva-anon-key
VITE_GOOGLE_CLIENT_ID=el-id-que-creaste-en-google-cloud

# Facebook SDK (loaded in browser)
VITE_FB_APP_ID=

# LinkedIn OAuth
VITE_LINKEDIN_APP_ID=
VITE_LINKEDIN_REDIRECT_URI=

# YouTube OAuth redirect
VITE_YOUTUBE_REDIRECT_URI=

# Threads OAuth
VITE_THREADS_APP_ID=
VITE_THREADS_REDIRECT_URI=
