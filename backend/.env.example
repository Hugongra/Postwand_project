# Desarrollo local (Vite proxy → https://127.0.0.1:5000 + rutas /api/...):
FLASK_API_PREFIX=/api

# Producción: si el reverse proxy envía a Flask sin prefijo /api, deja vacío:
# FLASK_API_PREFIX=

# --- Supabase (debe ser el MISMO proyecto que el frontend) ---
# URL: igual que VITE_SUPABASE_URL
SUPABASE_URL=https://tu-proyecto.supabase.co
# Clave pública "anon" (Dashboard → Project Settings → API): igual que VITE_SUPABASE_ANON_KEY
# Preferido explícito:
SUPABASE_ANON_KEY=tu-anon-key
# Opcional legacy: puedes usar solo SUPABASE_KEY con el mismo valor anon (no uses service_role aquí).
# SUPABASE_KEY=tu-anon-key
# Solo para admin/Celery (nunca para validar el JWT del usuario en @login_required):
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Depurar cabecera Authorization y fallos de get_user (Bearer): 1/true/yes
# DEBUG_AUTH=1

# --- Flask ---
FLASK_SECRET_KEY=change-me-in-production

# --- OpenAI ---
OPENAI_API_KEY=

# --- Redis (Celery) ---
UPSTASH_REDIS_HOST=localhost
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=
UPSTASH_REDIS_URL=redis://localhost:6379

# --- Zernio (unified social media API) ---
ZERNIO_API_KEY=sk_your-key-here

# --- Social Media API Keys (legacy — not needed if using Zernio) ---
# Facebook / Instagram (Meta): https://developers.facebook.com/apps/
FB_APP_ID=
FB_APP_SECRET=

# Threads: same Meta app, separate API
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=

# LinkedIn: https://www.linkedin.com/developers/apps/
LINKEDIN_APP_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# YouTube / Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID_YOUTUBE=
GOOGLE_CLIENT_SECRET_YOUTUBE=

# TikTok: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_CREATOR=price_...
STRIPE_PRICE_ID_MANAGER=price_...
STRIPE_PRICE_ID_BUSINESS=price_...
FRONTEND_URL=https://app.postwand.io
